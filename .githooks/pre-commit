#!/usr/bin/env sh
# Runs scripts/check.sh before every commit. Installed via
# scripts/install-hooks.sh. Skip once with: git commit --no-verify
set -eu
repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v luac5.1 >/dev/null 2>&1 || ! command -v texlua >/dev/null 2>&1; then
    echo "pre-commit: toolchain missing -- run 'sh scripts/dev-setup.sh' once, or commit with --no-verify to skip." >&2
    exit 1
fi

sh scripts/check.sh
